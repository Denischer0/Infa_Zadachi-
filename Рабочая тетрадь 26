Задача 8

import numpy as np
#Задача - Создать массив из чисел, написть код, создающий второй массив, элементы которого в два раза больше элементов первого массива

# Обычный Python

arr=[1,2,3,4,5]
result=[]
for i in range(len(arr)):
    result.append(arr[i]+arr[i])
print(result)

# Библиотека Numpy
arr = np.array([1, 2, 3, 4, 5])
result = arr + arr
print(result)

#На данно примере наглядно видно, что использование библиотеки Numpy позволяет сделать код компактнее, а также упрощает его написание.








