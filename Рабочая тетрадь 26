Задача 4

import pandas as pd

data = {'Категория': ['Техника', 'Одежда', 'Техника', 'Одежда'],
        'Продажи': [1000, 500, 800, 500]}
df = pd.DataFrame(data)
grouped_data = df.groupby('Категория')
total_sales = grouped_data['Продажи'].sum()
print(total_sales)

