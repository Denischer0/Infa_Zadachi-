def summ(a:str, b:str, base:int) -> str:
    a = a[::-1]
    b = b[::-1]
    carry = 0
    result = []
    for i in range(max(len(a), len(b))):
        da = int(a[i]) if i < len(a) else 0
        db = int(b[i]) if i < len(b) else 0
        s = da + db + carry
        result.append(str(s % base))
        carry = s // base
    if carry:
        result.append(str(carry))
    return ''.join(reversed(result))

def deff(a:str, b:str, base:int) -> str:
    a = a[::-1]
    b = b[::-1]
    borrow = 0
    result = []
    for i in range(len(a)):
        da = int(a[i]) - borrow
        db = int(b[i]) if i < len(b) else 0
        if da < db:
            da += base
            borrow = 1
        else:
            borrow = 0
        result.append(str(da - db))
    return "".join(reversed(result))

a, b, base = input(), input(), int(input())

sum_res = summ(a, b, base)
print(f"Сумма: {sum_res}")

diff_res = deff(sum_res, b, base)
print(f"Разность ({sum_res} - {b}): {diff_res}")
if diff_res.lstrip("0") == a.lstrip("0"):
    print("Success!")
else:
    print("Error!")

