def to_base(num:int, base:int) -> str:
    res = ''
    while num != 0:
        res += str(num % base)
        num //= base
    return res

num1 = 41
num2 = 14

for base in [2, 8, 10]:
    s1 = to_base(num1, base)
    s2 = to_base(num2, base)
    print(summ(s1, s2, base))


